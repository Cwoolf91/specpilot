{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "out",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["src/extension/**/*.ts", "src/core/**/*.ts"]
}
